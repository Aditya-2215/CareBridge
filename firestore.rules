rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User accounts
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Patient records
    match /patients/{patientId} {
      allow read: if isSignedIn();
      allow write: if isOwner(patientId);
    }

    // Doctor details
    match /doctors/{doctorId} {
      allow read: if true; // Anyone can view available doctors
      allow write: if isSignedIn() && request.auth.uid == doctorId;
    }

    // OTP verification tokens (strictly server-side/admin)
    match /otps/{otpId} {
      allow read, write: if false;
    }

    // Clinical consultation appointments
    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid || 
        resource.data.doctorId == request.auth.uid
      );
      allow write: if isSignedIn() && (
        request.resource.data.patientId == request.auth.uid ||
        request.resource.data.doctorId == request.auth.uid
      );
    }
  }
}
