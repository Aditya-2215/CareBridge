
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.

APP_URL="MY_APP_URL"

# MongoDB Connection String (Real database fallback to in-memory mock if empty)
MONGODB_URI="mongodb://localhost:27017/carebridge"

# SMTP Configuration for OTP & password resets (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# JWT Secret for secure backend-frontend authentication
JWT_SECRET="your-jwt-signing-secret-key"

# Super Admin credentials for enterprise access control
SUPER_ADMIN_EMAIL="admin@carebridge.com"
SUPER_ADMIN_PASSWORD="Admin123!"

# Google OAuth Credentials for Single Sign-On SSO (required for Google Login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
